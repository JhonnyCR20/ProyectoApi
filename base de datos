-- Tabla de usuarios del sistema
CREATE TABLE Grupo6_usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    correo VARCHAR(100) UNIQUE,
    clave VARCHAR(255),
    rol ENUM('admin', 'bibliotecario') NOT NULL
);

-- Tabla de lectores
CREATE TABLE Grupo6_lectores (
    id_lector INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    correo VARCHAR(100) UNIQUE,
    telefono VARCHAR(20),
    direccion TEXT
);

-- Tabla de autores
CREATE TABLE Grupo6_autores (
    id_autor INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    nacionalidad VARCHAR(50)
);

-- Tabla de editoriales
CREATE TABLE Grupo6_editoriales (
    id_editorial INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    pais VARCHAR(50)
);

-- Tabla de categorías de libros
CREATE TABLE Grupo6_categorias (
    id_categoria INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    descripcion TEXT
);

-- Tabla de libros
CREATE TABLE Grupo6_libros (
    id_libro INT AUTO_INCREMENT PRIMARY KEY,
    titulo VARCHAR(150),
    anio_publicacion YEAR,
    id_categoria INT,
    id_editorial INT,
    isbn VARCHAR(20) UNIQUE,
    cantidad_disponible INT,
    FOREIGN KEY (id_categoria) REFERENCES Grupo6_categorias(id_categoria),
    FOREIGN KEY (id_editorial) REFERENCES Grupo6_editoriales(id_editorial)
);

-- Relación muchos a muchos entre libros y autores
CREATE TABLE Grupo6_libros_autores (
    id_libro INT,
    id_autor INT,
    PRIMARY KEY (id_libro, id_autor),
    FOREIGN KEY (id_libro) REFERENCES Grupo6_libros(id_libro),
    FOREIGN KEY (id_autor) REFERENCES Grupo6_autores(id_autor)
);

-- Tabla de préstamos
CREATE TABLE Grupo6_prestamos (
    id_prestamo INT AUTO_INCREMENT PRIMARY KEY,
    id_lector INT,
    fecha_prestamo DATE,
    fecha_devolucion DATE,
    estado ENUM('activo', 'devuelto', 'retrasado') DEFAULT 'activo',
    FOREIGN KEY (id_lector) REFERENCES Grupo6_lectores(id_lector)
);

-- Detalle del préstamo
CREATE TABLE Grupo6_detalle_prestamo (
    id_detalle INT AUTO_INCREMENT PRIMARY KEY,
    id_prestamo INT,
    id_libro INT,
    cantidad INT,
    FOREIGN KEY (id_prestamo) REFERENCES Grupo6_prestamos(id_prestamo),
    FOREIGN KEY (id_libro) REFERENCES Grupo6_libros(id_libro)
);

-- Tabla de reservas
CREATE TABLE Grupo6_reservas (
    id_reserva INT AUTO_INCREMENT PRIMARY KEY,
    id_lector INT,
    id_libro INT,
    fecha_reserva DATE,
    estado ENUM('pendiente', 'completada', 'cancelada') DEFAULT 'pendiente',
    FOREIGN KEY (id_lector) REFERENCES Grupo6_lectores(id_lector),
    FOREIGN KEY (id_libro) REFERENCES Grupo6_libros(id_libro)
);

-- Tabla de multas
CREATE TABLE Grupo6_multas (
    id_multa INT AUTO_INCREMENT PRIMARY KEY,
    id_prestamo INT,
    monto DECIMAL(10,2),
    pagado BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (id_prestamo) REFERENCES Grupo6_prestamos(id_prestamo)
);

-- Historial de actividad
CREATE TABLE Grupo6_historial (
    id_historial INT AUTO_INCREMENT PRIMARY KEY,
    id_lector INT,
    accion VARCHAR(255),
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_lector) REFERENCES Grupo6_lectores(id_lector)
);

